# Required secrets
OPS_SESSION_SECRET=replace-with-token-urlsafe-32-output
OPS_AUTH_TOKEN=replace-with-engine-API_AUTH_TOKEN

# Engine identity — set these if the engine's docker-compose project name
# or container name differs from the defaults baked into this repo.
# ENGINE_CONTAINER_NAME=360scalp-v2-engine
# ENGINE_DATA_VOLUME=360-v2_360scalp-v2-data

# Optional overrides (defaults shown)
# ENGINE_API_BASE=https://api.luminapp.org
# ENGINE_DATA_DIR=/engine-data
# MONITOR_LOGS_BASE_URL=https://raw.githubusercontent.com/mkmk749278/360-v2/monitor-logs
# MONITOR_LOGS_TTL_SEC=60
# DIAG_TIMEOUT_SEC=30
# OPS_PORT=8000
# LOG_LEVEL=INFO
